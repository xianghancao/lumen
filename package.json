{
  "name": "lumen-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "Lumen: Jupyter-native notebook mind map view",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:kernel": "npm run build --workspace=lumen-kernel",
    "build:extension:lib": "npm run build:lib --workspace=jupyterlab-lumen",
    "build:extension": "npm run build:kernel && npm run build:extension:lib && npm run build:labextension:dev --workspace=jupyterlab-lumen",
    "jlab:install": "bash scripts/install-jupyterlab-extension.sh",
    "jlab:dev": "bash scripts/dev-jupyterlab.sh",
    "jlab:verify": "bash scripts/verify-jupyterlab-extension.sh"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.9.3"
  }
}
