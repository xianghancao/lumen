{
  "name": "kuusi-kernel",
  "version": "0.2.1",
  "description": "Notebook outline tree and dagre layout for Kuusi",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/notebook-outline.test.ts src/notebook-tree.test.ts src/layout.test.ts",
    "watch": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "dagre": "^0.8.5"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
